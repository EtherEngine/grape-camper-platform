# ── App ──────────────────────────────────────────────────
APP_ENV=local
APP_DEBUG=true
APP_TIMEZONE=Europe/Berlin

# ── Database ─────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=grape
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# ── CORS ─────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ── Session ──────────────────────────────────────────────
SESSION_LIFETIME_HOURS=72
SESSION_COOKIE_NAME=grape_session
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=Lax